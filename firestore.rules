rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'nsalinas42@gmail.com' || request.auth.token.email == 'felix.voyager@gmail.com');
    }

    // Validation Blueprint for User Document
    function isValidUser(data) {
      return (!('uid' in data) || (data.uid is string && data.uid.size() <= 128))
        && (!('name' in data) || (data.name is string && data.name.size() <= 200))
        && (!('email' in data) || (data.email is string && data.email.size() <= 200))
        && (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 1000))
        && (!('title' in data) || (data.title is string && data.title.size() <= 128))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000))
        && (!('secondaryEmail' in data) || (data.secondaryEmail is string && data.secondaryEmail.size() <= 200))
        && (!('passwordHash' in data) || (data.passwordHash is string && data.passwordHash.size() <= 128))
        && (!('recoveryToken' in data) || (data.recoveryToken is string && data.recoveryToken.size() <= 128))
        && (!('recoveryTokenExpires' in data) || (data.recoveryTokenExpires is string && data.recoveryTokenExpires.size() <= 128));
    }

    // Validation Blueprint for User Progress Document
    function isValidUserProgress(data) {
      return (!('uid' in data) || (data.uid is string && data.uid.size() <= 128))
        && (!('level' in data) || (data.level is number))
        && (!('xp' in data) || (data.xp is number))
        && (!('xpToNextLevel' in data) || (data.xpToNextLevel is number))
        && (!('linkedWallet' in data) || (data.linkedWallet is string && data.linkedWallet.size() <= 200))
        && (!('title' in data) || (data.title is string && data.title.size() <= 128))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000))
        && (!('locations' in data) || (data.locations is string && data.locations.size() <= 131072));
    }

    // Validation Blueprint for Settings Document
    function isValidSettings(data) {
      return data.walletEnabled is bool
        && data.network is string
        && (data.network == 'MAINET' || data.network == 'DEVNET');
    }

    // Rules for /test/{docId}
    match /test/{docId} {
      allow read: if true;
    }

    // Rules for /settings/{settingId}
    match /settings/{settingId} {
      allow get: if true; // Publicly accessible configurations
      allow create, update: if isAdmin()
        && isValidId(settingId)
        && isValidSettings(incoming())
        && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // Rules for /users/{userId}
    match /users/{userId} {
      allow get, list: if true; // Public retrieval/query enabled for custom email/password registry & recovery
      allow create: if isSignedIn()
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'name', 'email'])
        && incoming().createdAt == request.time
        && incoming().lastLogin == request.time;
      allow update: if (
        // Standard owner or admin updates
        ((isOwner(userId) || isAdmin()) 
          && isValidUser(incoming()) 
          && (!('lastLogin' in incoming()) || incoming().lastLogin == request.time)
          && (!('createdAt' in incoming()) || incoming().createdAt == existing().createdAt))
        ||
        // Unauthenticated user password recovery updates
        (incoming().diff(existing()).affectedKeys().hasOnly(['recoveryToken', 'recoveryTokenExpires', 'lastLogin']))
      );
      allow delete: if isAdmin();
    }

    // Rules for /user_progress/{userId}
    match /user_progress/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUserProgress(incoming())
        && incoming().keys().hasAll(['uid', 'level', 'xp', 'xpToNextLevel'])
        && incoming().updatedAt == request.time;
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUserProgress(incoming())
        && (!('updatedAt' in incoming()) || incoming().updatedAt == request.time);
      allow delete: if isAdmin();
    }
  }
}
